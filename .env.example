# ─── WBA ───
WBA_URL=https://new.wba.com.br/login/be9f33e9-b23e-4854-8004-8744f1877bf3
WBA_LOGIN=seu-login@exemplo.com
WBA_SENHA=sua-senha
# Cedentes a processar (separados por vírgula), exatamente como aparecem no WBA
CEDENTES=MUUH OUTSOURCING,FORT LIMP,IP ARTIGOS DE LIMPEZA LTDA,DISTRIBUIDORA GOIAS

# ─── E-mail (Locaweb) ───
EMAIL_SMTP_HOST=email-ssl.com.br
EMAIL_SMTP_PORT=465
EMAIL_IMAP_HOST=email-ssl.com.br
EMAIL_LOGIN=usuario@dominio.com.br
EMAIL_SENHA=senha-do-email
EMAIL_FROM=usuario@dominio.com.br
EMAIL_PASTA_ENVIADOS=INBOX.enviadas
# Planilha (pública via CSV) com colunas: Nome, CPF/CNPJ, Email, E-mail Cedente (CC)
EMAIL_SHEET_ID=1u8rRIxESjNT5Rs-ZEa7JecMbbkBZ84AhGJEX-1nAS7Q

# ─── Opcionais ───
# A resposta é "responder a todos": To = sacado, Cc = cedente + Luiz (quem estava
# na confirmação original). EMAIL_CC_FIXO adiciona uma cópia EXTRA além desses.
# Vazio = mantém só os destinatários originais da confirmação.
EMAIL_CC_FIXO=
# Destino do e-mail de resumo (default = EMAIL_FROM)
EMAIL_RESUMO_PARA=
# TESTE: redireciona TODOS os e-mails p/ este endereço (assunto [TESTE]).
EMAIL_TESTE=
# Navegador headless (true em produção; false p/ ver rodando local)
BOLETOS_EMAIL_HEADLESS=true
# Janela do vencimento (meses à frente)
BOLETOS_EMAIL_VENC_MESES=6
# Pasta de download (default /tmp/boletos_email)
DOWNLOAD_DIR=/tmp/boletos_email
